# Database used for publications, licenses, and users.
DB_DSN=postgres://user:pass@localhost:5432/dbname?sslmode=disable

# Readium LCP settings.
LCP_PROFILE=production
LCP_CERTIFICATE=/path/to/cert.pem
LCP_PRIVATE_KEY=/path/to/key.pem
LCP_PROVIDER_URI=https://yourdomain.com
LCP_CORE_URL=http://lcpserver:8989
LCP_CORE_USER=admin
LCP_CORE_PASSWORD=admin_pass

# Encrypted publication storage.
# Use "fs" for local files or "s3" for S3-compatible storage such as MinIO.
LCP_STORAGE_MODE=fs
LCP_STORAGE_FS_DIR=/var/lib/lcp/storage

# S3 / MinIO settings. These are used when LCP_STORAGE_MODE=s3.
LCP_S3_ENDPOINT=localhost:9000
LCP_S3_PUBLIC_ENDPOINT=localhost:9000
LCP_S3_REGION=us-east-1
LCP_S3_BUCKET=my-bucket
LCP_S3_ACCESS_KEY=your-access-key
LCP_S3_SECRET_KEY=your-secret-key
LCP_S3_USE_SSL=false
LCP_S3_SIGNED_URL_TTL_SECONDS=900

# Login and token settings for the built-in local auth flow.
JWT_SECRET=your-jwt-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_2FA_CODE=123456
PUBLISHER_USERNAME=publisher
PUBLISHER_PASSWORD=publisher
DEFAULT_TENANT_ID=default

# Public service URLs.
SERVER_PORT=:8080
PUBLIC_BASE_URL=http://localhost:8080
STATUS_BASE_URL=http://status.localhost:8990

# API behavior.
# Tenant records can override this with their own rateLimitRpm value.
RATE_LIMIT_RPM=600

# Optional webhook delivery.
# Multiple targets can be separated with commas.
WEBHOOK_URLS=
WEBHOOK_SECRET=
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_BACKOFF_MS=250

# Used for JSON-backed local persistence when PostgreSQL is not configured.
DATA_DIR=/var/lib/lcp/data
